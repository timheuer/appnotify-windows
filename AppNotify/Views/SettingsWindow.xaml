<Window
    x:Class="AppNotify.Views.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="App Notify — Settings">

    <Grid>
    <NavigationView x:Name="NavView" IsBackButtonVisible="Collapsed" PaneDisplayMode="Top"
                    SelectionChanged="NavView_SelectionChanged" IsSettingsVisible="False">
        <NavigationView.MenuItems>
            <NavigationViewItem Content="General" Tag="General">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE713;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Account" Tag="Account">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE77B;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Developer" Tag="Developer">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xEC7A;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.MenuItems>

        <ScrollViewer Padding="24">
            <StackPanel Spacing="16" MaxWidth="500">
                <!-- General Page -->
                <StackPanel x:Name="GeneralPanel" Spacing="16">
                    <TextBlock Text="Polling" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <StackPanel Spacing="4">
                        <TextBlock Text="Check every" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <ComboBox x:Name="PollingCombo" SelectionChanged="PollingChanged" Width="200">
                            <ComboBoxItem Content="30 minutes" Tag="30" />
                            <ComboBoxItem Content="1 hour" Tag="60" />
                            <ComboBoxItem Content="2 hours" Tag="120" />
                            <ComboBoxItem Content="8 hours" Tag="480" />
                        </ComboBox>
                    </StackPanel>

                    <TextBlock Text="Celebration Sound" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,8,0,0" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <ComboBox x:Name="SoundCombo" SelectionChanged="SoundChanged" Width="200">
                            <ComboBoxItem Content="Default Beep" Tag="Default" />
                            <ComboBoxItem Content="Asterisk" Tag="Asterisk" />
                            <ComboBoxItem Content="Exclamation" Tag="Exclamation" />
                            <ComboBoxItem Content="Hand" Tag="Hand" />
                            <ComboBoxItem Content="Question" Tag="Question" />
                        </ComboBox>
                        <Button Click="PreviewSoundClick" ToolTipService.ToolTip="Preview sound">
                            <FontIcon Glyph="&#xE995;" FontSize="14" />
                        </Button>
                    </StackPanel>
                </StackPanel>

                <!-- Account Page -->
                <StackPanel x:Name="AccountPanel" Spacing="16" Visibility="Collapsed">
                    <TextBlock Text="Account" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <StackPanel x:Name="ConnectedPanel" Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE73E;" Foreground="Green" />
                            <TextBlock Text="Connected to App Store Connect" VerticalAlignment="Center" />
                        </StackPanel>
                        <Button Content="Sign Out" Click="SignOutClick" />
                    </StackPanel>
                    <TextBlock x:Name="NotConnectedText" Text="Not connected"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" Visibility="Collapsed" />
                </StackPanel>

                <!-- Developer Page -->
                <StackPanel x:Name="DeveloperPanel" Spacing="16" Visibility="Collapsed">
                    <TextBlock Text="Simulation" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <StackPanel Spacing="8">
                        <Button Click="TriggerCelebrationClick" HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="🎉" />
                                <TextBlock Text="Trigger Celebration" />
                            </StackPanel>
                        </Button>
                        <Button Click="SimulateNotificationClick" HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="🔔" />
                                <TextBlock Text="Simulate Status Change Notification" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <TextBlock Text="State" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,8,0,0" />
                    <StackPanel Spacing="4">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Apps loaded:" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="AppsCountText" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Hidden apps:" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="HiddenCountText" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Polling interval:" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="PollingText" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Celebration sound:" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="SoundText" />
                        </StackPanel>
                        <Button x:Name="UnhideAllBtn" Content="Unhide All Apps" Click="UnhideAllClick" Margin="0,8,0,0" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </NavigationView>
    </Grid>
</Window>
