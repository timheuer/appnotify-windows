<UserControl
    x:Class="AppNotify.Views.MainFlyout"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="using:AppNotify.Helpers">

    <UserControl.Resources>
        <helpers:StatusColorConverter x:Key="StatusColorConverter" />
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisConverter" />
        <helpers:RelativeTimeConverter x:Key="RelativeTimeConverter" />
        <helpers:NullToVisibilityConverter x:Key="NullToVisConverter" />
        <helpers:StatusDisplayNameConverter x:Key="StatusDisplayNameConverter" />
    </UserControl.Resources>

    <Grid UseLayoutRounding="True" Padding="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Padding="16,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="App Store Notify" Style="{StaticResource SubtitleTextBlockStyle}" VerticalAlignment="Center" />
            <ProgressRing Grid.Column="1" IsActive="{Binding IsLoading, Mode=OneWay}"
                          Width="20" Height="20" Margin="8,0"
                          Visibility="{Binding IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisConverter}}" />
            <Button Grid.Column="2" Click="RefreshClick" Style="{StaticResource SubtleButtonStyle}" ToolTipService.ToolTip="Refresh">
                <FontIcon Glyph="&#xE72C;" FontSize="14" />
            </Button>
        </Grid>

        <!-- Error Bar -->
        <InfoBar Grid.Row="1" IsOpen="{Binding ErrorMessage, Mode=OneWay, Converter={StaticResource NullToVisConverter}}"
                 Severity="Error" Title="Error"
                 Message="{Binding ErrorMessage, Mode=OneWay}"
                 IsClosable="True" Margin="8,0" />

        <!-- App List -->
        <ScrollViewer Grid.Row="2" MaxHeight="420" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="AppsList" ItemsSource="{Binding GroupedApps, Mode=OneWay}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                      IsExpanded="{Binding IsExpanded, Mode=TwoWay}" Padding="0">
                                <Expander.Header>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Border CornerRadius="10" Padding="8,3"
                                                Background="{Binding Status, Converter={StaticResource StatusColorConverter}, ConverterParameter=Background}">
                                            <TextBlock Text="{Binding DisplayName}" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{Binding Status, Converter={StaticResource StatusColorConverter}}" />
                                        </Border>
                                        <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                   VerticalAlignment="Center" Text="{Binding Count, Mode=OneWay}" />
                                    </StackPanel>
                                </Expander.Header>
                                <ItemsControl ItemsSource="{Binding Apps}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Padding="16,10" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                                  BorderThickness="0,0,0,1">
                                                <Grid.ContextFlyout>
                                                    <MenuFlyout>
                                                        <MenuFlyoutItem Text="Hide This App" Tag="{Binding Id}" Click="HideAppClick">
                                                            <MenuFlyoutItem.Icon>
                                                                <FontIcon Glyph="&#xED1A;" />
                                                            </MenuFlyoutItem.Icon>
                                                        </MenuFlyoutItem>
                                                    </MenuFlyout>
                                                </Grid.ContextFlyout>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Spacing="2" MinWidth="0">
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding BundleId}" FontSize="11"
                                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                               TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" HorizontalAlignment="Right" Spacing="2" Margin="8,0,0,0">
                                                    <Border CornerRadius="10" Padding="8,3"
                                                            Background="{Binding LatestVersion.Status, Converter={StaticResource StatusColorConverter}, ConverterParameter=Background}">
                                                        <TextBlock Text="{Binding LatestVersion.Status, Converter={StaticResource StatusDisplayNameConverter}}"
                                                                   FontSize="11" FontWeight="SemiBold" TextWrapping="NoWrap"
                                                                   Foreground="{Binding LatestVersion.Status, Converter={StaticResource StatusColorConverter}}" />
                                                    </Border>
                                                    <TextBlock HorizontalAlignment="Right" FontSize="11"
                                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                               Text="{Binding LatestVersion.VersionString}" />
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Expander>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Footer -->
        <Grid Grid.Row="3" Padding="16,8" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,1,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}" VerticalAlignment="Center"
                       Text="{Binding LastUpdated, Mode=OneWay, Converter={StaticResource RelativeTimeConverter}}" />
            <Button x:Name="ShowAllBtn" Grid.Column="1" Content="Show All" Click="ShowAllClick"
                    Style="{StaticResource SubtleButtonStyle}" FontSize="12" Margin="4,0" />
            <Button Grid.Column="2" Content="Settings..." Click="SettingsClick"
                    Style="{StaticResource SubtleButtonStyle}" FontSize="12" Margin="4,0" />
            <Button Grid.Column="3" Content="Quit" Click="QuitClick"
                    Style="{StaticResource SubtleButtonStyle}" FontSize="12" />
        </Grid>
    </Grid>
</UserControl>
